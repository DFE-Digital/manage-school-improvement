@model (string AreaTitle, List<Dfe.ManageSchoolImprovement.Frontend.Models.SupportProject.ImprovementPlanObjectiveViewModel> Objectives, int SupportProjectId, string? ReturnPage, bool IsReadOnly, bool completedReviews)

@if (Model.Objectives.Any())
{
    <div class="govuk-summary-card">
        <div class="govuk-summary-card__title-wrapper">
            <h2 class="govuk-summary-card__title">@Model.AreaTitle</h2>
        </div>
        <div class="govuk-summary-card__content">
            <dl class="govuk-summary-list">
                @foreach (var objective in Model.Objectives)
                {
                    <div class="govuk-summary-list__row">
                        <dt class="govuk-summary-list__key">
                            Objective @(objective.Order)
                        </dt>
                        <dd class="govuk-summary-list__value">
                            @objective.Details
                        </dd>
                        @if (!Model.IsReadOnly)
                        {

                                <ul class="govuk-summary-card__actions">
                                    <li class="govuk-summary-card__action">
                                        <a class="govuk-link" asp-page="@Links.ImprovementPlan.ChangeAnObjective.Page"
                                           asp-route-id="@Model.SupportProjectId"
                                           asp-route-objectiveid="@objective.ReadableId"
                                           asp-route-returnpage="@Model.ReturnPage"
                                           data-cy="objective-summary-change-link">Change</a>
                                    </li>
                                    @if (!Model.completedReviews)
                                    {
                                        <li class="govuk-summary-card__action">
                                            <a class="govuk-link" asp-page="@Links.ImprovementPlan.DeleteAnObjective.Page"
                                               asp-route-id="@Model.SupportProjectId"
                                               asp-route-objectiveid="@objective.ReadableId"
                                               asp-route-returnpage="@Model.ReturnPage"
                                               data-cy="objective-summary-change-link">Delete</a>
                                        </li>  
                                    }
                                </ul>

                        }
                    </div>
                }
            </dl>
        </div>
    </div>
}