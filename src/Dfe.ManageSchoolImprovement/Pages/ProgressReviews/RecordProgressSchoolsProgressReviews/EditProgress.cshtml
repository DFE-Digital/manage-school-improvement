@page "/progress-reviews/review-progress-school/{id:int}/edit-progress"
@model Dfe.ManageSchoolImprovement.Frontend.Pages.ProgressReviews.RecordProgressSchoolsProgressReviews.EditProgressModel
@{
    ViewData["Title"] = "Record progress";
}

@section BeforeMain
{
    <nav aria-label="back navigation">
        <a asp-page="@Model.ReturnPage" asp-route-id="@Model.SupportProject?.Id" asp-route-reviewId="@Model.ReviewId"
            class="govuk-back-link" data-cy="back-link">Back</a>
    </nav>
}

@if (Model.ShowError)
{
    <partial name="_ErrorSummary" />
}

<div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
        <span class="govuk-caption-l">Progress review</span>
        <h1 class="govuk-heading-l" data-cy="page-heading">
            Record progress
        </h1>

        <form method="post" novalidate>
            <input type="hidden" asp-for="@Model.ReviewId" />

            <govuk-radiobuttons-input heading="Next steps"
                heading-style="govuk-fieldset__legend--m" name="@nameof(Model.NextSteps)" asp-for="@Model.NextSteps"
                radio-buttons="@Model.NextStepsRadioButtons" error-message="@Model.NextStepsErrorMessage"
                data-cy="next-steps-radios" />

            <div class="govuk-form-group">
                <h2 class="govuk-label-wrapper">
                    <label class="govuk-label govuk-label--m" for="AdditionalDetails">
                        Additional comments (optional)
                    </label>
                </h2>
                <textarea class="govuk-textarea"
                    id="@nameof(Model.AdditionalDetails)" name="@nameof(Model.AdditionalDetails)" rows="5" data-cy="additional-details-textarea"
                    asp-for="@Model.AdditionalDetails"></textarea>
            </div>

            <div class="govuk-button-group">

                    <button class="govuk-button" type="submit" data-cy="save-button" data-module="govuk-button">
                        Save
                    </button>
                    <a asp-page="@Model.ReturnPage" asp-route-id="@Model.SupportProject?.Id"
                       asp-route-reviewid="@Model.ReviewId"
                        class="govuk-link" data-cy="cancel-link">
                        Cancel
                    </a>
                
            </div>
        </form>
    </div>
</div>
