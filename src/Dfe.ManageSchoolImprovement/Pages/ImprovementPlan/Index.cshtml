@page "/improvement-plan/{id:int}"
@model IndexModel
@{
    ViewData["Title"] = "Improvement plan";
}

@section BeforeMain
{
    <a asp-page="@Model.ReturnPage" class="govuk-back-link">@Links.SchoolList.Index.BackText</a>
}
<partial name="_ProjectHeader" model="@Model.SupportProject"/>
<div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
        <h2 class="govuk-heading-l">Improvement plan</h2>
        <p>
            Once you have added the improvement plan objectives, they will be listed here.
        </p>
        <p>
            When they are, you should record progress on the objectives after each progress review.
        </p>
        
        <partial name="_ObjectiveSummaryCards" model="@Model.SupportProject"/>
    </div>
</div>