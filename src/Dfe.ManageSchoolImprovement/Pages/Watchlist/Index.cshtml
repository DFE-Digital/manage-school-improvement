@page "/watchlist"

@using Dfe.ManageSchoolImprovement.Utils
@using GovUK.Dfe.CoreLibs.Utilities.Extensions
@model Dfe.ManageSchoolImprovement.Frontend.Pages.Watchlist.IndexModel

@{
    ViewData["Title"] = "Your school watchlist";
    bool schoolAdded = (bool)(TempData["SchoolAdded"] ?? false);
    bool schoolRemoved = (bool)(TempData["SchoolRemoved"] ?? false);
}

@if (schoolAdded || schoolRemoved)
{
    <div class="govuk-notification-banner govuk-notification-banner--success" role="alert"
         aria-labelledby="govuk-notification-banner-title" data-module="govuk-notification-banner"
         cy-data="task-updated-success-notification">
        <div class="govuk-notification-banner__header">
            <h2 class="govuk-notification-banner__title" id="govuk-notification-banner-title">
                Success
            </h2>
        </div>
        <div class="govuk-notification-banner__content">
            <h3 class="govuk-notification-banner__heading" id="contact-added">
                @(schoolAdded ? "School added to watchlist" : "School removed from watchlist")
            </h3>
        </div>
    </div>
}

<div class="govuk-grid-row">
    <div class="govuk-grid-column-three-quarters">
        <h1 class="govuk-heading-xl">Your school watchlist</h1>
        <p class="govuk-body">
            You can use your watchlist to save schools that are important to you and find them quickly.
        </p>
        <a asp-page="@Links.Watchlist.SelectSchool.Page" class="govuk-button">Add school to watchlist</a>
    </div>
</div>
<div class=govuk-grid-row>
    <div class="govuk-grid-column-full">
        @if (Model.Watchlist.Count > 0)
        {
            <table class="govuk-table" data-module="moj-sortable-table">
                <caption class="govuk-table__caption govuk-visually-hidden">
                    My watched schools
                </caption>
                <thead class="govuk-table__head">
                <tr class="govuk-table__row">
                    <th scope="col" class="govuk-table__header govuk-!-width-one-quarter" aria-sort="none">
                        School
                    </th>
                    <th scope="col" class="govuk-table__header" aria-sort="none">
                        Date added to MSI
                    </th>
                    <th scope="col" class="govuk-table__header" aria-sort="none">
                        Assigned to
                    </th>
                    <th scope="col" class="govuk-table__header" aria-sort="none">
                        Supporting organisation
                    </th>
                    <th scope="col" class="govuk-table__header" aria-sort="none">
                        Milestone
                    </th>
                    <th scope="col" class="govuk-table__header" aria-sort="none">
                        Status
                    </th>
                </tr>
                </thead>
                <tbody class="govuk-table__body">
                @foreach (var watchedSchool in Model.Watchlist)
                {
                    var supportingOrganisationText = "Milestone not yet reached";
                    if (watchedSchool.SupportingOrganisationName != null)
                    {
                        supportingOrganisationText = watchedSchool.SupportingOrganisationName;
                    }
                    else if (watchedSchool.ReviewProgressSchool.HasValue && watchedSchool.ReviewProgressSchool.Value)
                    {
                        supportingOrganisationText = "Review progress school";
                    }

                    <tr class="govuk-table__row">
                        <td class="govuk-table__cell" data-sort-value="@watchedSchool.SchoolName">
                            <a class="govuk-link" asp-page="@Links.TaskList.Index.Page"
                               data-cy="school-name-@watchedSchool.SchoolName"
                               asp-route-id="@watchedSchool.SupportProjectId"
                               asp-route-returnpage="@Links.Watchlist.Index.Page">@watchedSchool.SchoolName</a>
                        </td>
                        <td class="govuk-table__cell"
                            data-sort-value="@(watchedSchool.DateAdded?.ToString("yyyyMMdd"))"
                            data-cy="date-added-@watchedSchool.DateAdded">@watchedSchool.DateAdded.ToDateString()</td>
                        <td class="govuk-table__cell"
                            data-sort-value="@watchedSchool.AssignedTo"
                            data-cy="assigned-to-@watchedSchool.SchoolName">@(watchedSchool.AssignedTo ?? "Not yet assigned")</td>
                        <td class="govuk-table__cell"
                            data-sort-value="@watchedSchool.SupportingOrganisationName">@(watchedSchool.SupportingOrganisationName ?? "Not yet appointed")</td>
                        <td class="govuk-table__cell"
                            data-sort-value="@watchedSchool.CurrentDeliveryMilestone">@supportingOrganisationText</td>
                        <td class="govuk-table__cell" data-sort-value="@watchedSchool.Status"
                            data-cy="status-@watchedSchool.Status">
                            <partial name="Shared/_ProjectStatus" model="watchedSchool.Status"/>
                        </td>
                        <td class="govuk-table__cell" data-cy="remove-link-@watchedSchool.SchoolName">
                            <a class="govuk-link" asp-page="@Links.Watchlist.RemoveSchool.Page"
                               asp-route-watchlistidtoremove="@watchedSchool.WatchlistId"
                               asp-route-readableidtoremove="@watchedSchool.ReadableId"
                               asp-route-selectedschoolid="@watchedSchool.SupportProjectId">Remove</a>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        }
        else
        {
            <p class="govuk-body"><strong>Your watchlist is currently empty.</strong></p>
        }

        <h2 class="govuk-heading-m">Helpful links (links open in a new tab)</h2>
        <h3 class="govuk-heading-s">Targeted RISE reporting</h3>
        <ul class="govuk-list govuk-list--bullet">
            <li>
                <a class="govuk-link" href="@Model.RiseDeliveryDashboardLink" rel="noreferrer noopener" target="_blank"
                   data-testid="rise-delivery-dashboard-link">RISE delivery dashboard</a></li>
            <li>
                <a class="govuk-link" href="@Model.RiseDataTablesLink" rel="noreferrer noopener" target="_blank"
                   data-testid="rise-data-tables-link">RISE data tables</a></li>
            <li>
                <a class="govuk-link" href="@Model.RiseMonitoringReportsLink" rel="noreferrer noopener" target="_blank"
                   data-testid="ofsted-inspection-reports-link">RISE monitoring report</a></li>
        </ul>
        <h3 class="govuk-heading-s">Information from other services</h3>
        <ul class="govuk-list govuk-list--bullet">
            <li>
                <a class="govuk-link" href="https://reports.ofsted.gov.uk/" rel="noreferrer noopener" target="_blank"
                   data-testid="ofsted-inspection-reports-link">See inspection reports at Ofsted</a></li>
            <li>
                <a class="govuk-link" href="https://www.get-information-schools.service.gov.uk/"
                   rel="noreferrer noopener"
                   target="_blank" data-testid="gias-link">Get information about schools</a></li>
            <li>
                <a class="govuk-link" href="https://www.find-information-schools-trusts.education.gov.uk/"
                   rel="noreferrer noopener" target="_blank" data-testid="fast-link">Find information about schools and
                    trusts</a></li>
        </ul>
    </div>
</div>
