@page "/is-this-school-eligible-for-intervention/{id:int}"

@model Dfe.ManageSchoolImprovement.Frontend.Pages.ProjectStatus.IsThisSchoolEligibleForInterventionModel

@{
    ViewData["Title"] = "Is this school eligible for targeted intervention?";
}

@section BeforeMain
{
    <nav aria-label="back navigation">
        <a asp-page="@Model.ReturnPage" class="govuk-back-link"
            asp-route-id="@Model.SupportProject?.Id">@Links.ProjectStatusTab.Index.BackText</a>
    </nav>
}

<partial name="_ErrorSummary" />

<div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
        <form method="post" novalidate>
            <div class="govuk-form-group">
                <div class="govuk-form-group">
                    <span class="govuk-caption-l">Change status and eligibility</span>
                    <fieldset class="govuk-fieldset">
                        <legend class="govuk-fieldset__legend govuk-fieldset__legend--l">
                            <h1 class="govuk-fieldset__heading" data-test="project-status">Is this school eligible for
                                targeted intervention?</h1>
                        </legend>
                        <div class="govuk-hint">
                            <p class="govuk-hint">The school's eligibility may have changed if they have had a new
                                Ofsted inspection or started a
                                conversion or transfer since being identified.</p>
                            <p class="govuk-hint">You can check the latest eligibility criteria in the
                                <a class="govuk-link"
                                    href="https://www.gov.uk/government/publications/schools-causing-concern--2"
                                    rel="noreferrer noopener" target="_blank"
                                    data-testid="ofsted-inspection-reports-link">support
                                    and intervention in schools guidance on GOV.UK (opens in new tab).</a>
                            </p>
                        </div>
                        <govuk-radiobuttons-input heading-style="govuk-fieldset__legend--m" inline="true"
                            name="@nameof(Model.SchoolIsEligible)" radio-buttons="@Model.RadioButtons"
                            asp-for="@Model.SchoolIsEligible" error-message="@Model.ErrorMessage" />
                    </fieldset>
                </div>
                <govuk-date-input heading-label="false" label="Enter date support is due to end (optional)"
                    id="support-is-due-to-end-date" name="support-is-due-to-end-date"
                    asp-for="@Model.DateSupportIsDueToEnd" hint="For example, 1 5 2026." />
            </div>
            <input type="hidden" asp-for="SupportProjectStatus" />
            <input type="hidden" asp-for="ProjectStatusChanged" />


            <button class="govuk-button" type="submit" id="save-and-continue-button" data-module="govuk-button"
                data-cy="select-common-submitbutton">
                Continue
            </button>
        </form>
    </div>
</div>
