@page "/check-your-answers/{id:int}"

@model Dfe.ManageSchoolImprovement.Frontend.Pages.ProjectStatus.CheckYourAnswersModel

@{
    ViewData["Title"] = "Check your answers";
}

@section BeforeMain
{
    <nav aria-label="back navigation">
        <a asp-page="@Model.ReturnPage" class="govuk-back-link"
           asp-route-id="@Model.SupportProject?.Id">@Links.ProjectStatusTab.ProjectStatusPausedDate.BackText</a>
    </nav>
}

<partial name="_ErrorSummary"/>

<div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
        <span class="govuk-caption-l">Change status and eligibility</span>
        <h1 class="govuk-label-wrapper" data-test="project-status-paused-details">
            <label class="govuk-label govuk-label--l">
                Check your answers
            </label>
        </h1>
        
        @if (@Model.ProjectStatusChanged)
        {

            <dl class="govuk-summary-list">

                <div class="govuk-summary-list__row">
                    <dt class="govuk-summary-list__key">
                        Current Elgibility
                    </dt>
                    <dd class="govuk-summary-list__value">
                        <strong class="govuk-tag govuk-tag--green">@Model.SupportProjectStatus</strong>
                    </dd>
                    <dd class="govuk-summary-list__actions">
                        <a class="govuk-link" href="change-project-status">Change<span class="govuk-visually-hidden"> project status</span></a>
                    </dd>
                </div>

                <div class="govuk-summary-list__row">
                    <dt class="govuk-summary-list__key">
                        Previous ProjectStatus
                    </dt>
                    <dd class="govuk-summary-list__value">
                        @Model.PreviousProgressStatus
                    </dd>
                </div>
                <div class="govuk-summary-list__row">
                    <dt class="govuk-summary-list__key">
                        Date of change
                    </dt>
                    <dd class="govuk-summary-list__value">
                        @Model.DateProjectStatusChanged
                    </dd>
                </div>

                <div class="govuk-summary-list__row">
                    <dt class="govuk-summary-list__key">
                        Details
                    </dt>
                    <dd class="govuk-summary-list__value">
                        @Model.ProjectStatusChangedDetails
                    </dd>
                </div>

            </dl>
        }
        
        @if (Model.EligibilityChanged)
        {
            <dl class="govuk-summary-list">

                <div class="govuk-summary-list__row">
                    <dt class="govuk-summary-list__key">
                        Current Eligibility
                    </dt>
                    <dd class="govuk-summary-list__value">
                        <strong class="govuk-tag govuk-tag--green">@Model.SchoolIsEligible
                            @if (Model.DateSupportIsDueToEnd.HasValue)
                            {
                                <text>, support ending on @Model.DateSupportIsDueToEnd.Value.ToString("d MMMM yyyy")</text>
                            }
                        </strong>
                    </dd>
                    <dd class="govuk-summary-list__actions">
                        <a class="govuk-link" href="change-project-status">Change<span class="govuk-visually-hidden"> project status</span></a>
                    </dd>
                </div>

                <div class="govuk-summary-list__row">
                    <dt class="govuk-summary-list__key">
                        Previous Eligibility
                    </dt>
                    <dd class="govuk-summary-list__value">
                        @Model.PreviousEligibility
                    </dd>
                </div>
                <div class="govuk-summary-list__row">
                    <dt class="govuk-summary-list__key">
                        Date of change
                    </dt>
                    <dd class="govuk-summary-list__value">
                        @Model.DateEligibilityChanged
                    </dd>
                </div>

                <div class="govuk-summary-list__row">
                    <dt class="govuk-summary-list__key">
                        Details
                    </dt>
                    <dd class="govuk-summary-list__value">
                        @Model.EligibilityChangedDetails
                    </dd>
                </div>

            </dl>
        }
        <form method="post" novalidate>
                <input type="hidden" asp-for="SupportProjectStatus" />
                <input type="hidden" name="DateProjectStatusChanged"
                       value="@Model.DateProjectStatusChanged?.ToString("yyyy-MM-dd")" />
                <input type="hidden" asp-for="ProjectStatusChangedDetails" />
                <input type="hidden" asp-for="ProjectStatusChanged" />
                
                <input type="hidden" asp-for="SchoolIsEligible" />
                <input type="hidden" asp-for="EligibilityChangedDetails" />
                <input type="hidden" name="DateProjectStatusChanged"
                       value="@Model.DateSupportIsDueToEnd?.ToString("yyyy-MM-dd")" />
                <input type="hidden" asp-for="DateSupportIsDueToEnd"/>
                <input type="hidden" name="DateProjectStatusChanged"
                       value="@Model.DateEligibilityChanged?.ToString("yyyy-MM-dd")" />
                <input type="hidden" asp-for="EligibilityChanged" />
                
            <button class="govuk-button" type="submit" id="continue-button" data-module="govuk-button"
                    data-cy="select-common-submitbutton">
                Save and return
            </button>
        </form>
    </div>
</div>
