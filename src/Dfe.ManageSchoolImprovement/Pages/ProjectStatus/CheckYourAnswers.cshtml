@page "/check-your-answers/{id:int}"

@using Dfe.ManageSchoolImprovement.Domain.ValueObjects
@using Dfe.ManageSchoolImprovement.Utils
@using GovUK.Dfe.CoreLibs.Utilities.Extensions
@model Dfe.ManageSchoolImprovement.Frontend.Pages.ProjectStatus.CheckYourAnswersModel

@{
    ViewData["Title"] = "Check your answers";
}

@section BeforeMain
{
    <nav aria-label="back navigation">
        <a asp-page="@Model.ReturnPage" class="govuk-back-link"
           asp-route-id="@Model.SupportProject?.Id">@Links.ProjectStatusTab.ProjectStatusPausedDate.BackText</a>
    </nav>
}

<partial name="_ErrorSummary"/>

<div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
        <span class="govuk-caption-l">Change status and eligibility</span>
        <h1 class="govuk-label-wrapper" data-test="project-status-paused-details">
            <label class="govuk-label govuk-label--l">
                Check your answers
            </label>
        </h1>
            <dl class="govuk-summary-list">
                <div class="govuk-summary-list__row">
                    <dt class="govuk-summary-list__key">
                        Current status
                    </dt>
                    <dd class="govuk-summary-list__value">
                        <partial name="Shared/_ProjectStatus" model="@Model.SupportProjectStatus"/>
                    </dd>
                    <dd class="govuk-summary-list__actions">
                        <a class="govuk-link" href="">Change<span class="govuk-visually-hidden"> project status</span></a>
                    </dd>
                </div>
                <div class="govuk-summary-list__row">
                    <dt class="govuk-summary-list__key">
                        Current eligibility
                    </dt>
                    <dd class="govuk-summary-list__value">
                        @if (Model.DateSupportIsDueToEnd.HasValue)
                        {
                            @Model.EligibilityStatus?.GetDisplayName()<span>, support ending on @Model.DateSupportIsDueToEnd.ToDateString()</span>
                        }
                        else
                        {
                            @Model.EligibilityStatus?.GetDisplayName()
                        }
                    </dd>
                </div>
                <div class="govuk-summary-list__row">
                    <dt class="govuk-summary-list__key">
                        Date of change
                    </dt>
                    <dd class="govuk-summary-list__value">
                        @Model.StatusOrEligiblityChangeDate.ToDateString()
                    </dd>
                </div>

                <div class="govuk-summary-list__row">
                    <dt class="govuk-summary-list__key">
                        Details
                    </dt>
                    <dd class="govuk-summary-list__value">
                        @Model.ChangeDetails
                    </dd>
                </div>

            </dl>
        <form method="post" novalidate>
                <input type="hidden" asp-for="SupportProjectStatus" />
                <input type="hidden" name="StatusOrEligiblityChangeDate"
                       value="@Model.StatusOrEligiblityChangeDate?.ToString("yyyy-MM-dd")" />
                <input type="hidden" asp-for="ChangeDetails" />
                <input type="hidden" asp-for="EligibilityStatus" />
                <input type="hidden" name="DateSupportIsDueToEnd"
                       value="@Model.DateSupportIsDueToEnd?.ToString("yyyy-MM-dd")" />
                
            <button class="govuk-button" type="submit" id="continue-button" data-module="govuk-button"
                    data-cy="select-common-submitbutton">
                Save and return
            </button>
        </form>
    </div>
</div>
