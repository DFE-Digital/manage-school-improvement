@page "/confirm-the-change/{id:int}"
@model Dfe.ManageSchoolImprovement.Frontend.Pages.ProjectStatus.ConfirmTheChangeModel

@{
    ViewData["Title"] = "Change project status";
}

@section BeforeMain
{
    <nav aria-label="back navigation">
        <a asp-page="@Model.ReturnPage" class="govuk-back-link" asp-route-id="@Model.SupportProject?.Id">@Links.ProjectStatusTab.Index.BackText</a>
    </nav>
}

<partial name="_ErrorSummary" />

<div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
        <span class="govuk-caption-l">Change status and eligibility</span>
        <h2 class="govuk-heading-l govuk-!-margin-bottom-2" data-test="project-status">Confirm the change</h2>
        <p>The previous status and eligibility was:</p>
        
        <div class="govuk-inset-text">
            <dl class="govuk-summary-list">
  
    
                <div class="govuk-summary-list__row">
                    <dt class="govuk-summary-list__key">
                        Previous status
                    </dt>
                    <dd class="govuk-summary-list__value">
                        <strong class="govuk-tag govuk-tag--green">@Model.PreviousProgressStatus</strong>
                    </dd>
      
                </div>
    
  
    
                <div class="govuk-summary-list__row">
                    <dt class="govuk-summary-list__key">
                        Previous eligibility
                    </dt>
                    <dd class="govuk-summary-list__value">
                        @Model.PreviousEligibility.ToString()
                    </dd>
      
                </div>
                
            
    
  
            </dl>
        </div>
        
        <p class-govuk-body>The current status and eligibility will be:</p>
        
        <div class="govuk-inset-text">
            <dl class="govuk-summary-list">
                <div class="govuk-summary-list__row">
                    <dt class="govuk-summary-list__key">
                        Current status
                    </dt>
                    <dd class="govuk-summary-list__value">
                        <strong class="govuk-tag govuk-tag--green">@Model.SupportProjectStatus.ToString()</strong>
                    </dd>
                </div>
                <div class="govuk-summary-list__row">
                    <dt class="govuk-summary-list__key">
                        Current eligibility
                    </dt>
                    <dd class="govuk-summary-list__value">
                        @Model.SchoolIsEligible.ToString()
                    </dd>
                </div>
            </dl>
        </div>
        <form method="post" novalidate>
            <govuk-date-input heading-label="false" label="When did the project status or eligibility change?"
                              id="eligibility-changed-date" name="eligibility-changed-date"
                              asp-for="@Model.DateEligibilityChanged" hint="For example, 1 5 2026."/>
            <input type="hidden" asp-for="SupportProjectStatus" />
            <input type="hidden" asp-for="DateSupportIsDueToEnd" />
            

            <button class="govuk-button" type="submit" id="save-and-continue-button" data-module="govuk-button"
                    data-cy="select-common-submitbutton">
                Save and return
            </button>
        </form>
    </div>
    
  
</div>

