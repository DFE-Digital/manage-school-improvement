@page "/enter-details-about-the-change/{id:int}"

@model Dfe.ManageSchoolImprovement.Frontend.Pages.ProjectStatus.EnterDetailsAboutTheChangeModel

@{
    ViewData["Title"] = "Enter details about the change";
}

@section BeforeMain
{
    <nav aria-label="back navigation">
        <a asp-page="@Model.ReturnPage" class="govuk-back-link"
           asp-route-id="@Model.SupportProject?.Id">@Links.ProjectStatusTab.ProjectStatusPausedDate.BackText</a>
    </nav>
}

<partial name="_ErrorSummary"/>

<div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
        <span class="govuk-caption-l">Change status and eligibility</span>
        <form method="post" novalidate>
            <h1 class="govuk-label-wrapper" data-test="project-status-paused-details">
                <label class="govuk-label govuk-label--l">
                    Enter details about the change
                </label>
            </h1>
            <div class="govuk-form-group @(Model.ShowError ? "govuk-form-group--error" : string.Empty)">
                <div class="govuk-hint">Provide details about the change and any next steps required.
                </div>
                <input type="hidden" asp-for="SupportProjectStatus" />
                <input type="hidden" asp-for="DateSupportIsDueToEnd" />
                <input type="hidden" asp-for="DateEligibilityChanged" />
                @if (Model.ShowError)
                {
                    <p id="more-detail-error" class="govuk-error-message">
                        <span class="govuk-visually-hidden">Error:</span> Enter details
                    </p>
                }
                <textarea class="govuk-textarea @(Model.ShowError ? "govuk-textarea--error" : string.Empty)"
                          id="project-status-changed-details" name="project-status-changed-details" rows="5"
                          asp-for="@Model.ProjectStatusChangedDetails" data-cy="paused-details-textarea"></textarea>
            </div>
            <button class="govuk-button" type="submit" id="continue-button" data-module="govuk-button"
                    data-cy="select-common-submitbutton">
                Continue
            </button>
        </form>
    </div>
</div>
