@page "/confirm-starting-eligibility/{id:int}"

@model Dfe.ManageSchoolImprovement.Frontend.Pages.AddSchool.ConfirmStartingEligibilityModel
@{
    ViewData["Title"] = "Confirm starting eligibility";
}

@section BeforeMain
{
    <nav aria-label="back navigation">
        <a asp-page="@Model.ReturnPage" asp-route-id="@Model.SupportProject?.Id"
           asp-route-urn="@Model.SupportProject?.SchoolUrn"
           asp-route-backlinkclicked="true"
           class="govuk-back-link">Back</a>
    </nav>
}

@if (Model.ShowError)
{
    <partial name="_ErrorSummary"/>
}

<div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
        <span class="govuk-caption-l">Confirm starting eligibility</span>
        <h1 id="eligibilityquestion" class="govuk-heading-l" data-cy="page-heading">
            Is this school eligible to begin targeted intervention?
        </h1>
        <p class="govuk-body">The school's eligibility may have changed if they have had an new Ofsted inspection or started a conversion or transfer since being identified.</p>
        <p class="govuk-body">You can check the latest eligibility criteria in the <a>support and intervention in schools guidance on GOV.UK (opens in new tab).</a></p>
            <form method="post" novalidate>
                <govuk-radiobuttons-input heading-style="govuk-fieldset__legend--m"
                                          name="@nameof(Model.SchoolIsEligible)" radio-buttons="@Model.RadioButtons"
                                          asp-for="@Model.SchoolIsEligible" error-message="@Model.ErrorMessage"/>

                <button class="govuk-button" type="submit" id="save-and-continue-button" data-module="govuk-button"
                        data-cy="select-common-submitbutton">
                    Continue
                </button>
            </form>
    </div>
</div>