@page "/eligibility-check-date/{id:int}"

@model Dfe.ManageSchoolImprovement.Frontend.Pages.AddSchool.EligibilityCheckDateModel
@{
    ViewData["Title"] = "When did the school's eligibility change?";
}

@section BeforeMain
{
    <nav aria-label="back navigation">
        <a asp-page="@Links.AddSchool.ConfirmStartingEligibility.Page" asp-route-id="@Model.SupportProject?.Id"
           class="govuk-back-link">Back</a>
    </nav>
}

@if (Model.ShowError)
{
    <partial name="_ErrorSummary"/>
}

<div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
        <span class="govuk-caption-l">Confirm starting eligibility</span>
        @* <h1 id="eligibilityquestion" class="govuk-heading-l" data-cy="page-heading"> *@
        @*     When did the school's eligibility change? *@
        @* </h1> *@
        <form method="post" novalidate>
            <govuk-date-input heading-label="false" label="When did the school's eligibility change?" id="eligibility-check-date"
                              name="eligibility-check-date" asp-for="@Model.DateEligibilityChanged" hint="For example, 1 7 2024."/>

            <button class="govuk-button" type="submit" id="save-and-continue-button" data-module="govuk-button"
                    data-cy="select-common-submitbutton">
                Continue
            </button>
        </form>
    </div>
</div>