@page "/eligibility-check-details/{id:int}"

@model Dfe.ManageSchoolImprovement.Frontend.Pages.AddSchool.EligibilityCheckDetailsModel
@{
    ViewData["Title"] = "Explain the reasons for the eligibility change";
}

@section BeforeMain
{
    <nav aria-label="back navigation">
        <a asp-page="@Model.ReturnPage" asp-route-id="@Model.SupportProject?.Id"
           class="govuk-back-link">Back</a>
    </nav>
}

@if (Model.ShowError)
{
    <partial name="_ErrorSummary"/>
}

<div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
        <span class="govuk-caption-l">Confirm starting eligibility</span>
        <form class="form" method="post" novalidate>
            <div
                class="govuk-form-group govuk-character-count @(Model.ShowError ? "govuk-form-group--error govuk-js-character-count--error" : "")"
                data-module="govuk-character-count"
                data-maxlength="500">
                <h1 class="govuk-label-wrapper">
                    <label id="eligibility-details" class="govuk-label govuk-label--l" data-cy="page-heading"
                           for="eligibility-check-details">
                        Explain the reasons for the eligibility change
                    </label>
                </h1>
                <div class="govuk-hint" id="eligibility-check-details-hint">
                    Provide details about why this school is no longer eligible and any next steps required.
                </div>
                @if (Model.ShowError)
                {
                    @if (Model.SchoolIsNotEligibleNotes == null)
                    {
                        <p id="eligibility-check-details-error" class="govuk-error-message">
                            <span class="govuk-visually-hidden">Error:</span> Enter details
                        </p>
                    }
                    else
                    {
                        <p id="character-count-error" class="govuk-error-message">
                            <span class="govuk-visually-hidden">Error:</span> Details must be 500 characters or
                            less
                        </p>
                    }
                }
                <textarea
                    class="govuk-textarea govuk-js-character-count @(Model.ShowError ? "govuk-textarea--error" : "")"
                    id="eligibility-check-details" name="eligibility-check-details"
                    rows="5">@Model.SchoolIsNotEligibleNotes</textarea>
                <div id="eligibility-check-details-info" class="govuk-hint govuk-character-count__message">
                    You can enter up to 500 characters
                </div>
            </div>
            <button class="govuk-button" type="submit" id="save-and-continue-button" data-module="govuk-button"
                    data-cy="select-common-submitbutton">
                Continue
            </button>
        </form>
    </div>
</div>